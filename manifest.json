{
  "manifest_version": 3,
  "name": "FocusValve",
  "version": "1.0.0",
  "description": "Blur noise and spoiler posts on Twitter (X) and Xiaohongshu (RED) using local AI. Zero server, fully private.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.xiaohongshu.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "FocusValve",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.xiaohongshu.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/transformers.min.js",
        "lib/ort-wasm-simd-threaded.wasm",
        "lib/ort-wasm-simd.wasm",
        "lib/ort-wasm-threaded.wasm",
        "lib/ort-wasm.wasm",
        "models/Xenova/all-MiniLM-L6-v2/*",
        "models/Xenova/all-MiniLM-L6-v2/onnx/*"
      ],
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.xiaohongshu.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
